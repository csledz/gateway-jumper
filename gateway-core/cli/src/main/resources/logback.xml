<configuration>
    <!-- Route every log event to STDERR so STDOUT stays clean for pipeable command output. -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{32} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="io.telekom.gateway.cli" level="INFO"/>

    <!-- Silence noisy clients by default; operators can override via -Dlogback.configurationFile. -->
    <logger name="io.fabric8" level="WARN"/>
    <logger name="okhttp3" level="WARN"/>
    <logger name="io.netty" level="WARN"/>
    <logger name="reactor" level="WARN"/>
    <logger name="org.mockserver" level="WARN"/>

    <root level="WARN">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
