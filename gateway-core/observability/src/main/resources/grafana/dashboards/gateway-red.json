{
  "annotations": { "list": [] },
  "description": "RED (Rate / Errors / Duration) view per gateway route. Backed by RedMetricsFilter.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Rate (requests/s) by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (route) (rate(gateway_requests_total{zone=~\"$zone\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error ratio (5xx / total) by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (route) (rate(gateway_requests_total{zone=~\"$zone\",status=~\"5..\"}[5m])) / ignoring(status) group_left sum by (route) (rate(gateway_requests_total{zone=~\"$zone\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Duration p95 by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (route, le) (rate(gateway_request_duration_seconds_bucket{zone=~\"$zone\"}[5m])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Duration p99 by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (route, le) (rate(gateway_request_duration_seconds_bucket{zone=~\"$zone\"}[5m])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Requests by status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (status) (rate(gateway_requests_total{zone=~\"$zone\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["gateway-core", "observability", "RED"],
  "templating": {
    "list": [
      {
        "name": "zone",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(gateway_requests_total, zone)",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "gateway-core :: RED (per route)",
  "uid": "gateway-core-red",
  "version": 1,
  "weekStart": ""
}
